<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SocialMediaApp.ViewModels"
             xmlns:models="clr-namespace:SocialMediaApp.Models"
             x:Class="SocialMediaApp.Views.HomePage"
             x:DataType="vm:HomeViewModel"
             Title="{Binding Title}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Logout"
                     Command="{Binding LogoutCommand}"/>
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,*" Padding="15" RowSpacing="10">

        <!-- Create Post Section -->
        <Frame Grid.Row="0"
               BorderColor="#E0E0E0"
               CornerRadius="12"
               Padding="15">
            <VerticalStackLayout Spacing="10">

                <Label Text="Create a Post"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="#5B4FCF"/>

                <Border Stroke="#E0E0E0" StrokeThickness="1"
                        StrokeShape="RoundRectangle 8">
                    <Entry Placeholder="Post Title"
                           Text="{Binding NewPostTitle}"
                           Margin="10,5"/>
                </Border>

                <Border Stroke="#E0E0E0" StrokeThickness="1"
                        StrokeShape="RoundRectangle 8">
                    <Editor Placeholder="What's on your mind?"
                            Text="{Binding NewPostBody}"
                            HeightRequest="80"
                            Margin="10,5"/>
                </Border>

                <Button Text="Post"
                        Command="{Binding CreatePostCommand}"
                        BackgroundColor="#5B4FCF"
                        TextColor="White"
                        CornerRadius="8"
                        HeightRequest="45"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"/>
            </VerticalStackLayout>
        </Frame>

        <!-- Loading Indicator -->
        <ActivityIndicator Grid.Row="1"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="#5B4FCF"/>

        <!-- Posts List -->
        <RefreshView Grid.Row="2"
                     Command="{Binding LoadPostsCommand}"
                     IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Posts}"
                            EmptyView="No posts available.">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Post">
                        <Frame Margin="0,5"
                               BorderColor="#E0E0E0"
                               CornerRadius="10"
                               Padding="15">
                            <Grid RowDefinitions="Auto,Auto,Auto"
                                  ColumnDefinitions="*,Auto,Auto"
                                  RowSpacing="5">

                                <!-- Post Title -->
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="{Binding Title}"
                                       FontAttributes="Bold"
                                       FontSize="15"
                                       TextColor="#333"/>

                                <!-- Update Button -->
                                <Button Grid.Row="0" Grid.Column="1"
                                        Text="✏️"
                                        BackgroundColor="Transparent"
                                        FontSize="18"
                                        Padding="5,0"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}},
                                                          Path=UpdatePostCommand}"
                                        CommandParameter="{Binding .}"/>

                                <!-- Delete Button -->
                                <Button Grid.Row="0" Grid.Column="2"
                                        Text="🗑️"
                                        BackgroundColor="Transparent"
                                        FontSize="18"
                                        Padding="5,0"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}},
                                                          Path=DeletePostCommand}"
                                        CommandParameter="{Binding .}"/>

                                <!-- Post Body -->
                                <Label Grid.Row="1" Grid.ColumnSpan="3"
                                       Text="{Binding Body}"
                                       FontSize="13"
                                       TextColor="Gray"
                                       MaxLines="3"
                                       LineBreakMode="TailTruncation"/>

                                <!-- User ID Tag -->
                                <Label Grid.Row="2" Grid.ColumnSpan="3"
                                       Text="{Binding UserId, StringFormat='👤 User {0}'}"
                                       FontSize="11"
                                       TextColor="#5B4FCF"/>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>