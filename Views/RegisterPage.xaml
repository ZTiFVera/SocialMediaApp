<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SocialMediaApp.ViewModels"
             x:Class="SocialMediaApp.Views.RegisterPage"
             x:DataType="vm:RegisterViewModel"
             Title=""
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FAFAFA">

    <ScrollView>
        <VerticalStackLayout Padding="0" Spacing="0" VerticalOptions="Center">

            <!-- Gradient Header -->
            <Grid HeightRequest="180">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#405DE6" Offset="0.0"/>
                        <GradientStop Color="#833AB4" Offset="0.3"/>
                        <GradientStop Color="#C13584" Offset="0.6"/>
                        <GradientStop Color="#F77737" Offset="1.0"/>
                    </LinearGradientBrush>
                </Grid.Background>

                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="4">
                    <Label Text="Instagram"
                           FontFamily="OpenSansSemibold"
                           FontSize="34"
                           TextColor="White"
                           HorizontalOptions="Center"/>
                    <Label Text="Sign up to see photos and videos"
                           FontSize="13"
                           TextColor="#FFFFFFCC"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Grid>

            <!-- Form -->
            <VerticalStackLayout Padding="30,28" Spacing="12" BackgroundColor="#FAFAFA">

                <!-- Mobile / Email -->
                <Border Stroke="#DBDBDB" StrokeThickness="1"
                        StrokeShape="RoundRectangle 4"
                        BackgroundColor="#EFEFEF">
                    <Entry Placeholder="Mobile number or email"
                           Text="{Binding Email}"
                           Keyboard="Email"
                           Margin="12,0" HeightRequest="44"
                           BackgroundColor="Transparent"/>
                </Border>

                <!-- Full name / Username -->
                <Border Stroke="#DBDBDB" StrokeThickness="1"
                        StrokeShape="RoundRectangle 4"
                        BackgroundColor="#EFEFEF">
                    <Entry Placeholder="Username"
                           Text="{Binding Username}"
                           Margin="12,0" HeightRequest="44"
                           BackgroundColor="Transparent"/>
                </Border>

                <!-- Password -->
                <Border Stroke="#DBDBDB" StrokeThickness="1"
                        StrokeShape="RoundRectangle 4"
                        BackgroundColor="#EFEFEF">
                    <Entry Placeholder="Password"
                           Text="{Binding Password}"
                           IsPassword="True"
                           Margin="12,0" HeightRequest="44"
                           BackgroundColor="Transparent"/>
                </Border>

                <!-- Terms notice -->
                <Label TextColor="#8E8E8E" FontSize="11" HorizontalTextAlignment="Center" Margin="0,4">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="By signing up, you agree to our "/>
                            <Span Text="Terms" TextColor="#3897F0"/>
                            <Span Text=", "/>
                            <Span Text="Privacy Policy" TextColor="#3897F0"/>
                            <Span Text=" and "/>
                            <Span Text="Cookies Policy" TextColor="#3897F0"/>
                            <Span Text="."/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>

                <!-- Sign Up Button -->
                <Grid HeightRequest="44" Margin="0,4,0,0">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#833AB4" Offset="0.0"/>
                            <GradientStop Color="#C13584" Offset="0.5"/>
                            <GradientStop Color="#E1306C" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <Button Text="Sign Up"
                            Command="{Binding RegisterCommand}"
                            BackgroundColor="Transparent"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="14"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"/>
                </Grid>

                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="#C13584" Margin="0,4"/>

            </VerticalStackLayout>

            <!-- Divider -->
            <BoxView HeightRequest="0.8" BackgroundColor="#DBDBDB" Margin="0,8"/>

            <!-- Already have account -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4" Padding="0,14">
                <Label Text="Have an account?"
                       FontSize="13" TextColor="#262626" VerticalOptions="Center"/>
                <Button Text="Log in."
                        Command="{Binding GoBackCommand}"
                        BackgroundColor="Transparent"
                        TextColor="#C13584"
                        FontAttributes="Bold"
                        FontSize="13"
                        Padding="0"/>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
