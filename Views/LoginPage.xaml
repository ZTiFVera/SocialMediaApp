<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SocialMediaApp.ViewModels"
             x:Class="SocialMediaApp.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">

            <Label Text="🌐 SocialApp"
                   FontSize="36" FontAttributes="Bold"
                   HorizontalOptions="Center" TextColor="#5B4FCF"/>

            <Label Text="Welcome Back!"
                   FontSize="18" HorizontalOptions="Center" TextColor="Gray"/>

            <Border Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 10">
                <Entry Placeholder="Username" Text="{Binding Username}" Margin="10,5"/>
            </Border>

            <Border Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 10">
                <Entry Placeholder="Password" Text="{Binding Password}"
                       IsPassword="True" Margin="10,5"/>
            </Border>

            <Button Text="Login"
                    Command="{Binding LoginCommand}"
                    BackgroundColor="#5B4FCF" TextColor="White"
                    CornerRadius="10" HeightRequest="50"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"/>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}" Color="#5B4FCF"/>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                <Label Text="Don't have an account?" VerticalOptions="Center"/>
                <Button Text="Register"
                        Command="{Binding GoToRegisterCommand}"
                        BackgroundColor="Transparent" TextColor="#5B4FCF"
                        FontAttributes="Bold" Padding="0"/>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>