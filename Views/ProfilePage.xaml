<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SocialMediaApp.ViewModels"
             x:Class="SocialMediaApp.Views.ProfilePage"
             x:DataType="vm:ProfileViewModel"
             BackgroundColor="White"
             Title="Profile">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Profile Header -->
            <Grid Padding="16,20,16,12"
                  ColumnDefinitions="Auto,*"
                  ColumnSpacing="20"
                  BackgroundColor="White">

                <!-- Story-ring Avatar -->
                <Grid Grid.Column="0" WidthRequest="86" HeightRequest="86">
                    <!-- Gradient ring -->
                    <Ellipse WidthRequest="86" HeightRequest="86">
                        <Ellipse.Fill>
                            <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                                <GradientStop Color="#FCAF45" Offset="0.0"/>
                                <GradientStop Color="#F77737" Offset="0.2"/>
                                <GradientStop Color="#E1306C" Offset="0.5"/>
                                <GradientStop Color="#C13584" Offset="0.75"/>
                                <GradientStop Color="#833AB4" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <!-- White border -->
                    <Ellipse WidthRequest="80" HeightRequest="80"
                             Fill="White"
                             HorizontalOptions="Center" VerticalOptions="Center"/>
                    <!-- Avatar content -->
                    <Label Text="👤" FontSize="40"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Grid>

                <!-- Stats -->
                <Grid Grid.Column="1"
                      ColumnDefinitions="*,*,*"
                      VerticalOptions="Center">
                    <!-- Posts -->
                    <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                        <Label Text="{Binding PostsCount}"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="#262626"
                               HorizontalOptions="Center"/>
                        <Label Text="Posts" FontSize="12"
                               TextColor="#262626"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <!-- Followers -->
                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                        <Label Text="2.4K"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="#262626"
                               HorizontalOptions="Center"/>
                        <Label Text="Followers" FontSize="12"
                               TextColor="#262626"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <!-- Following -->
                    <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                        <Label Text="512"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="#262626"
                               HorizontalOptions="Center"/>
                        <Label Text="Following" FontSize="12"
                               TextColor="#262626"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Grid>
            </Grid>

            <!-- Bio Section -->
            <VerticalStackLayout Padding="16,0,16,14" BackgroundColor="White" Spacing="2">
                <Label Text="{Binding Username}"
                       FontAttributes="Bold" FontSize="14" TextColor="#262626"/>
                <Label Text="{Binding Bio}"
                       FontSize="13" TextColor="#262626"/>
                <Label Text="{Binding Email}"
                       FontSize="12" TextColor="#3897F0"/>
            </VerticalStackLayout>

            <!-- Action Buttons Row -->
            <Grid Padding="12,0,12,14" ColumnDefinitions="*,*,Auto"
                  ColumnSpacing="8" BackgroundColor="White"
                  IsVisible="{Binding IsEditing, Converter={StaticResource InvertedBoolConverter}}">

                <Border Grid.Column="0"
                        Stroke="#DBDBDB" StrokeThickness="1"
                        StrokeShape="RoundRectangle 6"
                        HeightRequest="32">
                    <Button Text="Edit Profile"
                            Command="{Binding EditProfileCommand}"
                            BackgroundColor="Transparent"
                            TextColor="#262626"
                            FontAttributes="Bold"
                            FontSize="13"/>
                </Border>

                <Border Grid.Column="1"
                        Stroke="#DBDBDB" StrokeThickness="1"
                        StrokeShape="RoundRectangle 6"
                        HeightRequest="32">
                    <Button Text="Share Profile"
                            BackgroundColor="Transparent"
                            TextColor="#262626"
                            FontAttributes="Bold"
                            FontSize="13"/>
                </Border>

                <Border Grid.Column="2"
                        Stroke="#DBDBDB" StrokeThickness="1"
                        StrokeShape="RoundRectangle 6"
                        HeightRequest="32" WidthRequest="32">
                    <Button Text="+"
                            BackgroundColor="Transparent"
                            TextColor="#262626"
                            FontAttributes="Bold"
                            FontSize="16"/>
                </Border>
            </Grid>

            <!-- Edit Form (visible when editing) -->
            <VerticalStackLayout Padding="16,0,16,14" Spacing="10"
                                 BackgroundColor="White"
                                 IsVisible="{Binding IsEditing}">

                <Label Text="Edit Profile"
                       FontSize="16" FontAttributes="Bold"
                       TextColor="#262626"/>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Username" FontSize="11" TextColor="#8E8E8E"/>
                    <Border Stroke="#DBDBDB" StrokeThickness="1"
                            StrokeShape="RoundRectangle 4"
                            BackgroundColor="#EFEFEF">
                        <Entry Text="{Binding Username}"
                               Margin="12,0" HeightRequest="44"
                               BackgroundColor="Transparent"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Email" FontSize="11" TextColor="#8E8E8E"/>
                    <Border Stroke="#DBDBDB" StrokeThickness="1"
                            StrokeShape="RoundRectangle 4"
                            BackgroundColor="#EFEFEF">
                        <Entry Text="{Binding Email}"
                               Keyboard="Email"
                               Margin="12,0" HeightRequest="44"
                               BackgroundColor="Transparent"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Bio" FontSize="11" TextColor="#8E8E8E"/>
                    <Border Stroke="#DBDBDB" StrokeThickness="1"
                            StrokeShape="RoundRectangle 4"
                            BackgroundColor="#EFEFEF">
                        <Editor Text="{Binding Bio}"
                                HeightRequest="80" Margin="12,5"
                                BackgroundColor="Transparent"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Save / Cancel -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,4,0,0">
                    <Grid Grid.Column="0" HeightRequest="40">
                        <Grid.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#833AB4" Offset="0.0"/>
                                <GradientStop Color="#C13584" Offset="0.5"/>
                                <GradientStop Color="#E1306C" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Grid.Background>
                        <Button Text="Save"
                                Command="{Binding SaveProfileCommand}"
                                BackgroundColor="Transparent"
                                TextColor="White"
                                FontAttributes="Bold"
                                FontSize="14"/>
                    </Grid>

                    <Border Grid.Column="1"
                            Stroke="#DBDBDB" StrokeThickness="1"
                            StrokeShape="RoundRectangle 6"
                            HeightRequest="40">
                        <Button Text="Cancel"
                                Command="{Binding CancelEditCommand}"
                                BackgroundColor="Transparent"
                                TextColor="#262626"
                                FontAttributes="Bold"
                                FontSize="14"/>
                    </Border>
                </Grid>
            </VerticalStackLayout>

            <!-- Highlight bubbles placeholder -->
            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never"
                        BackgroundColor="White" Padding="12,4,12,12">
                <HorizontalStackLayout Spacing="16">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="6">
                        <Border StrokeShape="RoundRectangle 38"
                                Stroke="#DBDBDB" StrokeThickness="1"
                                WidthRequest="68" HeightRequest="68"
                                BackgroundColor="#EFEFEF">
                            <Label Text="+" FontSize="28" TextColor="#8E8E8E"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="New" FontSize="11" TextColor="#262626" HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout HorizontalOptions="Center" Spacing="6">
                        <Border StrokeShape="RoundRectangle 38"
                                Stroke="#DBDBDB" StrokeThickness="1"
                                WidthRequest="68" HeightRequest="68"
                                BackgroundColor="#EFEFEF">
                            <Label Text="⭐" FontSize="28"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="Favs" FontSize="11" TextColor="#262626" HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout HorizontalOptions="Center" Spacing="6">
                        <Border StrokeShape="RoundRectangle 38"
                                Stroke="#DBDBDB" StrokeThickness="1"
                                WidthRequest="68" HeightRequest="68"
                                BackgroundColor="#EFEFEF">
                            <Label Text="🌅" FontSize="28"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="Travel" FontSize="11" TextColor="#262626" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </ScrollView>

            <!-- Divider + Grid/Tag tabs -->
            <BoxView HeightRequest="0.5" BackgroundColor="#DBDBDB"/>
            <Grid ColumnDefinitions="*,*" BackgroundColor="White">
                <Border Grid.Column="0"
                        Stroke="#262626"
                        StrokeThickness="1"
                        Padding="0,10">
                    <Label Text="" FontSize="24" TextColor="#262626"
           HorizontalOptions="Center"/>
                </Border>
                <Border Grid.Column="1"
                        Stroke="Transparent" StrokeThickness="0"
                        Padding="0,10">
                    <Label Text="🏷" FontSize="22" TextColor="#8E8E8E"
                           HorizontalOptions="Center"/>
                </Border>
            </Grid>
            <BoxView HeightRequest="0.5" BackgroundColor="#DBDBDB"/>

            <!-- Post Grid placeholder -->
            <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto"
                  ColumnSpacing="2" RowSpacing="2"
                  BackgroundColor="#FAFAFA" Margin="0,2,0,0">

                <!-- Row 1 -->
                <Grid Grid.Row="0" Grid.Column="0" HeightRequest="130">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#405DE6" Offset="0"/>
                            <GradientStop Color="#833AB4" Offset="1"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <Label Text="📸" FontSize="36" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Grid>
                <Grid Grid.Row="0" Grid.Column="1" HeightRequest="130">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#C13584" Offset="0"/>
                            <GradientStop Color="#F77737" Offset="1"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <Label Text="🌅" FontSize="36" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Grid>
                <Grid Grid.Row="0" Grid.Column="2" HeightRequest="130">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#E1306C" Offset="0"/>
                            <GradientStop Color="#FCAF45" Offset="1"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <Label Text="✨" FontSize="36" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Grid>

                <!-- Row 2 -->
                <Grid Grid.Row="1" Grid.Column="0" HeightRequest="130">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FCAF45" Offset="0"/>
                            <GradientStop Color="#E1306C" Offset="1"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <Label Text="🎨" FontSize="36" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Grid>
                <Grid Grid.Row="1" Grid.Column="1" HeightRequest="130">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#833AB4" Offset="0"/>
                            <GradientStop Color="#C13584" Offset="1"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <Label Text="🌸" FontSize="36" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Grid>
                <Grid Grid.Row="1" Grid.Column="2" HeightRequest="130">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#405DE6" Offset="0"/>
                            <GradientStop Color="#E1306C" Offset="1"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <Label Text="🎭" FontSize="36" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Grid>
            </Grid>

            <!-- Logout -->
            <Button Text="Log Out"
                    Command="{Binding LogoutCommand}"
                    BackgroundColor="Transparent"
                    TextColor="#E1306C"
                    FontAttributes="Bold"
                    FontSize="14"
                    Margin="16,20,16,30"
                    BorderColor="#DBDBDB"
                    BorderWidth="1"
                    CornerRadius="6"
                    HeightRequest="44"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
