<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="SocialMediaApp.App">

    <Application.Resources>
        <ResourceDictionary>

            <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter"/>

            <!-- Instagram Core Palette -->
            <Color x:Key="IGPurple">#833AB4</Color>
            <Color x:Key="IGPink">#C13584</Color>
            <Color x:Key="IGOrange">#E1306C</Color>
            <Color x:Key="IGYellow">#F77737</Color>
            <Color x:Key="IGGold">#FCAF45</Color>
            <Color x:Key="IGBlue">#405DE6</Color>

            <!-- Neutrals -->
            <Color x:Key="IGBackground">#FAFAFA</Color>
            <Color x:Key="IGWhite">#FFFFFF</Color>
            <Color x:Key="IGBlack">#000000</Color>
            <Color x:Key="IGDivider">#DBDBDB</Color>
            <Color x:Key="IGTextPrimary">#262626</Color>
            <Color x:Key="IGTextSecondary">#8E8E8E</Color>
            <Color x:Key="IGLightGray">#EFEFEF</Color>

            <!-- Global Button Style -->
            <Style TargetType="Button">
                <Setter Property="FontFamily" Value="OpenSansSemibold"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="0"/>
            </Style>

            <Style TargetType="Entry">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="TextColor" Value="#262626"/>
                <Setter Property="PlaceholderColor" Value="#AAAAAA"/>
            </Style>

            <Style TargetType="Label">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="TextColor" Value="#262626"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>

</Application>
